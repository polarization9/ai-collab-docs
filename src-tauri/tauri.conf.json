{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Margent",
  "mainBinaryName": "Margent",
  "version": "0.1.1",
  "identifier": "com.margent.desktop",
  "build": {
    "beforeDevCommand": "npm run build:web && npm run dev:web",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist/web"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/margent-server"],
    "resources": {
      "../dist": "_up_/dist",
      "../node_modules": "_up_/node_modules",
      "resources/node": "resources/node",
      "resources/en.lproj": "en.lproj",
      "resources/zh-Hans.lproj": "zh-Hans.lproj"
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "contentTypes": [
          "public.markdown",
          "net.daringfireball.markdown"
        ],
        "mimeType": "text/markdown",
        "name": "Markdown Document",
        "role": "Editor",
        "rank": "Alternate"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["margent"]
      }
    }
  }
}
